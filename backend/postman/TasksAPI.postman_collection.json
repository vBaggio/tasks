{
	"info": {
		"name": "TasksAPI",
		"description": "Task Management System - REST API (Horse + Delphi)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "basic",
		"basic": [
			{
				"key": "username",
				"value": "{{username}}",
				"type": "string"
			},
			{
				"key": "password",
				"value": "{{password}}",
				"type": "string"
			}
		]
	},
	"item": [
		{
			"name": "Tasks",
			"item": [
				{
					"name": "Listar todas as tarefas",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/tasks",
							"host": ["{{baseUrl}}"],
							"path": ["tasks"]
						}
					}
				},
				{
					"name": "Criar tarefa",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"Minha nova tarefa\",\n  \"description\": \"Descri\u00e7\u00e3o da tarefa\",\n  \"priority\": 2\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/tasks",
							"host": ["{{baseUrl}}"],
							"path": ["tasks"]
						}
					}
				},
				{
					"name": "Atualizar status da tarefa",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"status\": 1\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/tasks/{{taskId}}/status",
							"host": ["{{baseUrl}}"],
							"path": ["tasks", "{{taskId}}", "status"]
						}
					}
				},
				{
					"name": "Remover tarefa",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/tasks/{{taskId}}",
							"host": ["{{baseUrl}}"],
							"path": ["tasks", "{{taskId}}"]
						}
					}
				}
			]
		},
		{
			"name": "Estat\u00edsticas",
			"item": [
				{
					"name": "Obter estat\u00edsticas",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/tasks/stats",
							"host": ["{{baseUrl}}"],
							"path": ["tasks", "stats"]
						}
					}
				}
			]
		},
		{
			"name": "Auth",
			"item": [
				{
					"name": "Testar sem credenciais (401)",
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/tasks",
							"host": ["{{baseUrl}}"],
							"path": ["tasks"]
						}
					}
				},
				{
					"name": "Testar credenciais inv\u00e1lidas (401)",
					"request": {
						"auth": {
							"type": "basic",
							"basic": [
								{
									"key": "username",
									"value": "wrong",
									"type": "string"
								},
								{
									"key": "password",
									"value": "wrong",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/tasks",
							"host": ["{{baseUrl}}"],
							"path": ["tasks"]
						}
					}
				}
			]
		}
	]
}
